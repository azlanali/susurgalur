# Copy to .env.local and fill in. NEVER commit .env.local.

# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key — bypasses RLS. Used ONLY by /api/admin/stats and /api/health.
# Keep out of anything NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=

# Simple gate for the admin stats API until real auth lands (Stage 2 step 3).
# Set any long random string in production; leave empty in local dev.
ADMIN_STATS_TOKEN=

# PostHog (analytics + error tracking) — optional until launch
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
